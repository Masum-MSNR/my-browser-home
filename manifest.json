{
  "manifest_version": 3,
  "name": "My Chrome Tab",
  "version": "1.3.2",
  "description": "A customizable new tab page for Chrome",
  "key": "",
  "chrome_url_overrides": {
    "newtab": "./tab/index.html"
  },
  "permissions": [
    "storage",
    "favicon",
    "webNavigation",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "./background/background.js"
  },
  "content_security_policy": {
    "extension_pages": "style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; script-src 'self'; object-src 'self'"
  }
}